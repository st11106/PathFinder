@{
    ViewData["Title"] = "PathFinder Engine";
}

<div class="container mt-4">
    <h2 class="mb-3">RasterRoute: Pathfinding per AMR (Multi-Tappa)</h2>

    <div class="row mb-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label text-muted small">1. Planimetria (PNG/JPEG)</label>
            <input type="file" id="imageInput" class="form-control" accept="image/png, image/jpeg" />
        </div>
        <div class="col-md-3">
            <label class="form-label text-muted small">2. Metadati ROS (JSON)</label>
            <input type="file" id="metaInput" class="form-control" accept="application/json" />
        </div>
        <div class="col-md-2">
            <label class="form-label text-muted small">Pixel per Cella</label>
            <input type="number" id="cellSizeInput" class="form-control" value="10" min="1" title="Definisce la dimensione logica della cella per A*" />
        </div>
        <div class="col-md-2">
            <label class="form-label text-muted small">Raggio Robot (metri)</label>
            <input type="number" id="robotRadiusInput" class="form-control" value="0.25" min="0" step="0.01" title="Raggio fisico del robot in metri. Verrà convertito in celle usando la risoluzione della mappa." />
            <small id="radiusCellsHint" class="text-muted" style="display:none;"></small>
        </div>
        <div class="col-md-2">
            <label class="form-label text-muted small">Orientamento Fin. (°)</label>
            <input type="number" id="finalAngleInput" class="form-control" placeholder="Es. 90" title="Angolo assoluto in gradi all'ultimo punto (opzionale)" />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <div class="alert alert-info py-2 m-0" id="statusMessage">
                Carica immagine e metadati per iniziare.
            </div>
        </div>
        <div class="col-md-6 text-end">
            <button id="btnReset" class="btn btn-secondary">Resetta Punti</button>
            <button id="btnCalculate" class="btn btn-primary" disabled>3. Calcola Percorso</button>
            <button id="btnDownload" class="btn btn-success" style="display: none;">4. Scarica JSON AMR</button>
        </div>
    </div>

    <div id="speedLegend" class="mb-2 text-center small" style="display: none;">
        <span><strong>Legenda Velocità:</strong></span>
        <span class="badge ms-1" style="background-color: #00ff00; color: black;">1.0 (Veloce)</span>
        <span class="badge ms-1" style="background-color: #99ff00; color: black;">0.8</span>
        <span class="badge ms-1" style="background-color: #ffff00; color: black;">0.6 (Medio)</span>
        <span class="badge ms-1" style="background-color: #ff9900; color: black;">0.4</span>
        <span class="badge ms-1" style="background-color: #ff0000; color: white;">0.2 (Lento)</span>
        <span class="badge ms-1" style="background-color: #800000; color: white;">0.0 (Fermo)</span>
    </div>

    <div style="overflow: auto; border: 1px solid #ccc; background-color: #f8f9fa;">
        <canvas id="mapCanvas" style="cursor: crosshair; display: none;"></canvas>
    </div>
</div>

@section Scripts {
    <script>
        const imageInput = document.getElementById('imageInput');
        const metaInput = document.getElementById('metaInput');
        const finalAngleInput = document.getElementById('finalAngleInput');

        const canvas = document.getElementById('mapCanvas');
        const ctx = canvas.getContext('2d');

        const btnCalculate = document.getElementById('btnCalculate');
        const btnReset = document.getElementById('btnReset');
        const btnDownload = document.getElementById('btnDownload');
        const statusMessage = document.getElementById('statusMessage');
        const cellSizeInput = document.getElementById('cellSizeInput');
        const robotRadiusInput = document.getElementById('robotRadiusInput');

        let currentImage = new Image();
        let imageFile = null;
        let metaFile = null;

        // Array che contiene tutti i punti selezionati dall'utente (Multi-tappa)
        let pointsArray = [];
        let currentAmrPath = null; // Variabile globale per conservare i dati da scaricare

        // --- 1. GESTIONE CARICAMENTO FILE ---

        imageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;

            imageFile = file;
            const reader = new FileReader();

            reader.onload = function(event) {
                currentImage.onload = function() {
                    canvas.width = currentImage.width;
                    canvas.height = currentImage.height;
                    canvas.style.display = 'block';
                    resetCanvas();
                }
                currentImage.src = event.target.result;
            }
            reader.readAsDataURL(file);
        });

        // Risoluzione (metri/pixel) letta dai metadati ROS, usata per l'anteprima celle.
        let mapResolution = null;
        const radiusCellsHint = document.getElementById('radiusCellsHint');

        metaInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                metaFile = file;
                console.log("Metadati caricati:", metaFile.name);

                // Leggiamo la risoluzione per mostrare l'anteprima del raggio in celle
                const reader = new FileReader();
                reader.onload = function(ev) {
                    try {
                        const meta = JSON.parse(ev.target.result);
                        mapResolution = meta.resolution;
                        updateRadiusHint();
                    } catch (err) {
                        console.warn("Impossibile leggere la risoluzione dai metadati:", err);
                    }
                };
                reader.readAsText(file);
            }
        });

        // Mostra all'utente a quante celle corrisponde il raggio in metri inserito.
        // Replica la stessa formula del backend: celle = metri / (resolution * cellSize)
        function updateRadiusHint() {
            const meters = parseFloat(robotRadiusInput.value);
            const cellSize = parseInt(cellSizeInput.value) || 1;

            if (!mapResolution || mapResolution <= 0 || isNaN(meters) || meters <= 0) {
                radiusCellsHint.style.display = 'none';
                return;
            }

            const metersPerCell = mapResolution * cellSize;
            const cells = Math.max(1, Math.round(meters / metersPerCell));
            radiusCellsHint.innerText = `\u2248 ${cells} cell${cells === 1 ? 'a' : 'e'} (${metersPerCell.toFixed(3)} m/cella)`;
            radiusCellsHint.style.display = 'block';
        }

        robotRadiusInput.addEventListener('input', updateRadiusHint);
        cellSizeInput.addEventListener('input', updateRadiusHint);

        // --- 2. GESTIONE CLICK SUL CANVAS (MULTI-TAPPA) ---

        canvas.addEventListener('mousedown', function(e) {
            const rect = canvas.getBoundingClientRect();
            const scaleX = canvas.width / rect.width;
            const scaleY = canvas.height / rect.height;

            const x = Math.floor((e.clientX - rect.left) * scaleX);
            const y = Math.floor((e.clientY - rect.top) * scaleY);

            // Aggiungiamo il nuovo punto all'array
            pointsArray.push({ x: x, y: y });

            // Ridisegniamo tutto per aggiornare i colori
            redrawAllMarkers();

            if (pointsArray.length === 1) {
                statusMessage.innerText = "Partenza impostata. Ora clicca per i punti intermedi o l'arrivo.";
                statusMessage.className = "alert alert-warning py-2 m-0";
            } else {
                statusMessage.innerText = `Selezionati ${pointsArray.length} punti. Clicca 'Calcola' o aggiungi altre tappe.`;
                statusMessage.className = "alert alert-success py-2 m-0";
                btnCalculate.disabled = false;
            }
        });

        function redrawAllMarkers() {
            // Pulisci e ridisegna la mappa di sfondo
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            if (currentImage.src) {
                ctx.drawImage(currentImage, 0, 0);
            }

            // Ridisegna tutti i marker con i colori corretti
            for (let i = 0; i < pointsArray.length; i++) {
                let color = 'blue'; // Colore di default per le tappe intermedie
                if (i === 0) color = 'green'; // Primo punto: Partenza
                if (i === pointsArray.length - 1 && pointsArray.length > 1) color = 'red'; // Ultimo punto: Arrivo

                drawMarker(pointsArray[i].x, pointsArray[i].y, color, (i + 1).toString());
            }
        }

        // --- 3. CHIAMATA AL BACKEND E CALCOLO ---

        btnCalculate.addEventListener('click', async function() {
            // Validazione client: servono almeno 2 punti e i file
            if (pointsArray.length < 2 || !imageFile) return;
            if (!metaFile) {
                alert("ATTENZIONE: Devi caricare il file JSON dei Metadati (ROS) prima di calcolare il percorso.");
                return;
            }

            btnCalculate.disabled = true;
            btnCalculate.innerText = "Calcolo in corso...";
            btnDownload.style.display = 'none';

            // Preparazione payload multipart
            const formData = new FormData();
            formData.append('image', imageFile);
            formData.append('metadataFile', metaFile);

            // Invia l'intero array di punti come stringa JSON
            formData.append('waypointsJson', JSON.stringify(pointsArray));

            formData.append('cellSize', cellSizeInput.value || 10);
            // Il backend si aspetta il raggio in METRI (parametro 'robotRadiusMeters')
            // e lo converte internamente in celle tramite la risoluzione dei metadati.
            formData.append('robotRadiusMeters', robotRadiusInput.value || 0.25);

            // Angolo finale opzionale
            if (finalAngleInput.value !== "") {
                formData.append('finalAngleDeg', finalAngleInput.value);
            }

            try {
                const response = await fetch('/Home/CalculatePath', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success && result.path.length > 0) {
                    // Ridisegna i marker per sicurezza prima di disegnare la linea
                    redrawAllMarkers();
                    drawPath(result.path);

                    // Salva la parte AMR per il download
                    currentAmrPath = result.path.map(p => p.amr);

                    statusMessage.innerText = `Percorso trovato! (${result.path.length} manovre generate).`;
                    statusMessage.className = "alert alert-success py-2 m-0";
                    btnDownload.style.display = 'inline-block';
                    document.getElementById('speedLegend').style.display = 'block'; // Mostra legenda
                } else {
                    statusMessage.innerText = "Nessun percorso trovato. Forse una delle tappe è irraggiungibile.";
                    statusMessage.className = "alert alert-danger py-2 m-0";
                }
            } catch (error) {
                statusMessage.innerText = "Si è verificato un errore durante il calcolo.";
                statusMessage.className = "alert alert-danger py-2 m-0";
                console.error(error);
            } finally {
                btnCalculate.innerText = "3. Calcola Percorso";
                btnCalculate.disabled = false;
            }
        });

        // --- 4. GESTIONE DOWNLOAD JSON PER AMR ---

        btnDownload.addEventListener('click', function() {
            if (!currentAmrPath) return;

            const jsonString = JSON.stringify(currentAmrPath, null, 2);
            const blob = new Blob([jsonString], { type: "application/json" });
            const url = URL.createObjectURL(blob);

            const a = document.createElement('a');
            a.href = url;
            a.download = "robot_trajectory_multi.json";
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        });

        // --- 5. FUNZIONI HELPER GRAFICHE ---

        btnReset.addEventListener('click', resetCanvas);

        function resetCanvas() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            if (currentImage.src) {
                ctx.drawImage(currentImage, 0, 0);
            }
            pointsArray = []; // Pulisce le tappe
            currentAmrPath = null;

            btnCalculate.disabled = true;
            btnDownload.style.display = 'none';
            document.getElementById('speedLegend').style.display = 'none'; // Nasconde legenda
            statusMessage.innerText = "Clicca sull'immagine per impostare il punto di partenza (A).";
            statusMessage.className = "alert alert-info py-2 m-0";
        }

        function drawMarker(x, y, color, text) {
            ctx.beginPath();
            ctx.arc(x, y, 6, 0, 2 * Math.PI, false); // Pallino leggermente più grande per contenere il numero
            ctx.fillStyle = color;
            ctx.fill();
            ctx.lineWidth = 2;
            ctx.strokeStyle = 'white';
            ctx.stroke();

            ctx.fillStyle = 'white';
            ctx.font = 'bold 10px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(text, x, y); // Testo centrato nel pallino
        }

        function getColorForSpeed(speed) {
            if (speed >= 1.0) return '#00ff00'; // Verde
            if (speed >= 0.8) return '#99ff00'; // Verde chiaro
            if (speed >= 0.6) return '#ffff00'; // Giallo
            if (speed >= 0.4) return '#ff9900'; // Arancio
            if (speed > 0.0) return '#ff0000';  // Rosso
            return '#800000'; // Rosso scuro (Fermo)
        }

        function drawPath(pathArray) {
            if (!pathArray || pathArray.length === 0) return;

            // Disegna i segmenti colorati in base alla velocità determinata dall'A*/Optimizer
            for (let i = 0; i < pathArray.length - 1; i++) {
                let startPt = pathArray[i].canvas;
                let endPt = pathArray[i + 1].canvas;

                // Leggiamo la velocità prevista per questo tratto dal metadato "amr"
                // Se è esattamente 0.0 (il punto d'arresto finale), preleviamo la velocità 
                // del nodo precedente per non mostrare un intero rettilineo colorato di "fermo".
                let speed = pathArray[i].amr.speed;
                if (speed === 0.0 && i > 0) {
                    speed = pathArray[i - 1].amr.speed;
                }

                let segmentColor = getColorForSpeed(speed);

                ctx.beginPath();
                ctx.moveTo(startPt.x, startPt.y);
                ctx.lineTo(endPt.x, endPt.y);

                ctx.strokeStyle = segmentColor;
                ctx.lineWidth = 4;
                ctx.lineJoin = 'round';
                ctx.stroke();
            }

            // Disegna i waypoints (pallini) con il loro colore di riferimento
            for (let i = 0; i < pathArray.length; i++) {
                let pt = pathArray[i].canvas;
                let speed = pathArray[i].amr.speed;

                // Mantiene il colore fermo (0.0) solo per il vero ultimo punto finale, visivamente
                if (speed === 0.0 && i < pathArray.length - 1 && i > 0) {
                     speed = pathArray[i - 1].amr.speed;
                }

                ctx.beginPath();
                ctx.arc(pt.x, pt.y, 4, 0, 2 * Math.PI, false);
                ctx.fillStyle = getColorForSpeed(speed);
                ctx.fill();
                ctx.lineWidth = 1;
                ctx.strokeStyle = 'black';
                ctx.stroke();

                // Calcoliamo l'angolo per la freccia di orientamento in modo visivamente corretto
                let heading = 0;
                if (i < pathArray.length - 1) {
                    let nextPt = pathArray[i + 1].canvas;
                    heading = Math.atan2(nextPt.y - pt.y, nextPt.x - pt.x);
                } else if (i > 0) {
                    // All'arrivo mantiene l'angolo dell'ultimo tratto
                    let prevPt = pathArray[i - 1].canvas;
                    heading = Math.atan2(pt.y - prevPt.y, pt.x - prevPt.x);
                }

                drawRobotHeading(pt.x, pt.y, heading);
            }
        }

        function drawRobotHeading(x, y, absoluteTheta) {
            ctx.save();
            ctx.translate(x, y);
            ctx.rotate(absoluteTheta);

            ctx.beginPath();
            ctx.moveTo(0, 0);
            ctx.lineTo(20, 0);
            ctx.lineTo(13, -5);
            ctx.moveTo(20, 0);
            ctx.lineTo(13, 5);

            ctx.strokeStyle = 'red';
            ctx.lineWidth = 2;
            ctx.stroke();

            ctx.restore();
        }
    </script>
}